# ---------------------------------------------------------------------------
# Anthropic API (required)
# Get your key from https://console.anthropic.com/
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxx

# ---------------------------------------------------------------------------
# Sentry (optional — leave blank to disable error monitoring locally)
# NEXT_PUBLIC_SENTRY_DSN is exposed to the browser; SENTRY_DSN is server-side.
# The remaining vars are set by `pnpm dlx @sentry/wizard@latest -i nextjs`.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Failure simulation (optional)
# Probability (0..1) that POST /api/messages returns a simulated 500.
# Default: 0.10. Set to 0 to disable for clean demos.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FAILURE_SIM_RATE=0.10
